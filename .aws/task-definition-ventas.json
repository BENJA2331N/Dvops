{
  "family": "ventas-task",
  "containerDefinitions": [
    {
      "name": "ventas-backend",
      "image": "ventas-image-placeholder",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8082,
          "hostPort": 8082,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_ENDPOINT",
          "value": "base-de-datos"
        },
        {
          "name": "DB_PORT",
          "value": "3306"
        },
        {
          "name": "DB_NAME",
          "value": "despacho_db"
        },
        {
          "name": "DB_USERNAME",
          "value": "despacho_user"
        },
        {
          "name": "DB_PASSWORD",
          "value": "despacho_password"
        },
        {
          "name": "SERVER_PORT",
          "value": "8082"
        }
      ]
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512"
}
