{
  "family": "frontend-task",
  "containerDefinitions": [
    {
      "name": "despacho-frontend",
      "image": "frontend-image-placeholder",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "BACKEND_HOST",
          "value": "api-despachos"
        },
        {
          "name": "VENTAS_HOST",
          "value": "api-ventas"
        }
      ]
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512"
}
