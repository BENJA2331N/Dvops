{
  "family": "despachos-task",
  "containerDefinitions": [
    {
      "name": "despacho-backend",
      "image": "despachos-image-placeholder",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8081,
          "hostPort": 8081,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_ENDPOINT",
          "value": "base-de-datos"
        },
        {
          "name": "DB_PORT",
          "value": "3306"
        },
        {
          "name": "DB_NAME",
          "value": "despacho_db"
        },
        {
          "name": "DB_USERNAME",
          "value": "despacho_user"
        },
        {
          "name": "DB_PASSWORD",
          "value": "despacho_password"
        }
      ]
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512"
}
